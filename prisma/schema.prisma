generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id          String        @id @default(cuid())
  title       String
  date        DateTime      @db.Date
  startTime   DateTime      @db.Time(0)
  endTime     DateTime      @db.Time(0)
  location    String
  isRecurring Boolean       @default(false)
  status      SessionStatus @default(OPEN)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  courts      Court[]
  cost        SessionCost?

  @@index([date, status])
}

model Court {
  id            String         @id @default(cuid())
  sessionId     String
  session       Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name          String
  maxSlots      Int            @default(10)
  warnAt        Int            @default(8)
  createdAt     DateTime       @default(now())
  registrations Registration[]

  @@index([sessionId])
}

model Registration {
  id               String    @id @default(cuid())
  courtId          String
  court            Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  registrantName   String
  registrantPhone  String
  playerName       String
  playerGender     Gender
  playerRank       String    // "NB", "Y+", "TB--", "K++" etc.
  isProxy          Boolean   @default(false)
  cancelToken      String    @unique @default(cuid())
  status           RegStatus @default(CONFIRMED)
  notified         Boolean   @default(false)
  isPaid           Boolean   @default(false)
  paidAt           DateTime?
  registeredAt     DateTime  @default(now())
  cancelledAt      DateTime?

  @@index([courtId, status])
  @@index([registrantPhone])
  @@index([cancelToken])
}

// Chi phí của một buổi chơi — admin nhập sau khi buổi kết thúc
model SessionCost {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  courtFee        Int      @default(0) // tiền sân (VNĐ)
  shuttlecockCost Int      @default(0) // tiền cầu
  supplyCost      Int      @default(0) // nước, băng, v.v.
  otherCost       Int      @default(0) // chi phí khác
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  pinHash   String
  createdAt DateTime @default(now())
}

// Liên kết phone number với Telegram chat_id sau khi user /start bot
model TelegramUser {
  id        String   @id @default(cuid())
  phone     String   @unique // normalized: digits only, no leading +
  chatId    String   @unique // Telegram chat_id
  firstName String?
  username  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

enum SessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RegStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
}

